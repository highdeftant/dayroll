#!/usr/bin/env bash
set -euo pipefail

blocked_pattern='(^|/)(\.dayroll/|todos\.json$|\.config/dayroll/)'

staged_files=$(git diff --cached --name-only)
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

if echo "${staged_files}" | grep -Eq "${blocked_pattern}"; then
  echo "ERROR: Refusing to commit local Dayroll data/config files." >&2
  echo "Blocked patterns: .dayroll/, todos.json, .config/dayroll/" >&2
  echo "Use: git reset HEAD <file>  (to unstage)" >&2
  exit 1
fi
